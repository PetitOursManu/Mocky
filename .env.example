# Mocky environment variables (copy to .env and fill in)
# This file is git-ignored — never commit real secrets.

# --- SSO: "Sign in with Dashy" (optional) ---
# The same HS256 secret Dashy signs SSO tokens with (must match Dashy's SSO_SHARED_SECRET)
# SSO_SHARED_SECRET=
# The public origin of your Dashy instance
# SSO_DASHY_URL=https://dashy.example.com
# Mocky's own public origin (used as the token's `aud` claim and callback URL)
# MOCKY_ORIGIN=https://mocky.example.com

# --- Server ---
# PORT=8787
# NODE_ENV=production